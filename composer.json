{
  "name": "dcplibrary/test",
  "require": {
    "php": ">=8.2",
    "illuminate/support": "^10.0||^11.0||^12.0"
  },
  "type": "library",
  "description": "Laravel package for test",
  "keywords": [
    "laravel",
    "package"
  ],
  "license": "MIT",
  "require-dev": {
    "phpunit/phpunit": "^10.0||^11.0",
    "orchestra/testbench": "^9.0||^10.0",
    "mockery/mockery": "^1.6",
    "squizlabs/php_codesniffer": "^3.0"
  },
  "authors": [
    {
      "name": "Brian Lashbrook",
      "email": "blashbrook@dcplibrary.org",
      "homepage": "https://www.dcplibrary.org",
      "role": "Developer"
    }
  ],
  "homepage": "https://www.dcplibrary.org",
  "autoload": {
    "psr-4": {
      "Dcplibrary\\Test\\": "src/",
      "Dcplibrary\\Test\\App\\": "src/app"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Dcplibrary\\Test\\Tests\\": "src/tests/"
    }
  },
  "extra": {
    "branch-alias": {
      "dev-main": "1.0.x-dev"
    },
    "laravel": {
      "providers": [
        "Dcplibrary\\Test\\App\\Providers\\TestServiceProvider"
      ],
      "aliases": {
        "Test": "Dcplibrary\\Test\\Facades\\Test"
      }
    }
  },
  "scripts": {
    "test": "phpunit",
    "lint": "phpcs",
    "lint-fix": "phpcbf",
    "docs": [
      "@putenv PHPDOC_PHAR=phpDocumentor.phar",
      "[ -f phpDocumentor.phar ] || curl -sL https://github.com/phpDocumentor/phpDocumentor/releases/latest/download/phpDocumentor.phar -o phpDocumentor.phar",
      "php phpDocumentor.phar --config phpdoc.xml"
    ]
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
